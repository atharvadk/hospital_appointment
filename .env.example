# ==============================================================================
# Aegis Health Manager - Environment Variables Template
# Copy this file to '.env' and populate with your credentials.
# ==============================================================================

# Backend Security
JWT_SECRET=super-secret-hospital-key-change-in-prod-12345

# LLM Configuration (Gemini API)
# Get a key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Google Calendar OAuth 2.0 Integration
# Set up OAuth 2.0 client credentials in Google Cloud Console
# Enabled APIs: Google Calendar API
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/calendar/callback

# SMTP Email Configuration (Optional - Falls back to Mock Log mode if empty)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_email@gmail.com
SMTP_PASSWORD=your_smtp_app_password
SENDER_EMAIL=notifications@clinicmanager.com

# Frontend Server
FRONTEND_URL=http://localhost:5173
